{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "container/server.ts",
    "scripts/*.ts",
    "test/**/*.test.ts",
    "*.config.ts"
  ],
  "project": [
    "src/**/*.ts",
    "cli/**/*.ts",
    "container/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "*.ts"
  ],
  "ignoreDependencies": ["@biomejs/biome"]
}
