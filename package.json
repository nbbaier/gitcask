{
  "name": "gitcask",
  "type": "module",
  "private": true,
  "bin": {
    "gitcask": "./cli/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "ultracite": "7.3.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply gitcask-db --local",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "bun ./cli/index.ts",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "citty": "^0.2.1",
    "cloudflare": "^5.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9"
  }
}
